generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
}

// ALL YOUR MODELS REMAIN EXACTLY THE SAME - don't change anything below
model Contact {
  id        Int      @id @default(autoincrement())
  firstName String
  lastName  String
  email     String
  phone     String
  message   String
  createdAt DateTime @default(now())
}

model Newsletter {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  createdAt DateTime @default(now())
}

model JobApplication {
  id             String   @id @default(uuid())
  name           String
  email          String
  phone          String
  vacancy String   @default("Not specified")
  cvUrl          String?
  createdAt      DateTime @default(now())
}

model InternshipApplication {
  id             String   @id @default(uuid())
  name           String
  email          String
  phone          String
  internshipType String   @default("Not specified")
  cvUrl          String?
  createdAt      DateTime @default(now())
}

model EquipmentRentalInquiry {
  id        Int      @id @default(autoincrement())
  firstName String
  lastName  String
  email     String
  phone     String
  message   String
  createdAt DateTime @default(now())
}

model MeasurementVerificationInquiry {
  id        Int      @id @default(autoincrement())
  firstName String
  lastName  String
  email     String
  phone     String
  message   String
  createdAt DateTime @default(now())
}

model ReemInquiry {
  id        Int      @id @default(autoincrement())
  firstName String
  lastName  String
  email     String
  phone     String
  message   String
  createdAt DateTime @default(now())
}

model EMSInquiry {
  id        Int      @id @default(autoincrement())
  firstName String
  lastName  String
  email     String
  phone     String
  message   String
  createdAt DateTime @default(now())
}
